#!/usr/bin/env python3
"""privacy-scan — block operator personal data from shipping.

Scans the *added* lines of a git diff for personal data and returns a non-zero
exit if any is found. Wired into ship-check as a blocking gate so that AOS —
which auto-updates on friends' machines — never carries the operator's private
information into framework code.

What it looks for:
  (a) denylist terms   — the operator's names, emails, phones, personal domains,
                         and top contacts, read from ~/.aos/config/privacy-denylist.txt
                         (case-insensitive; word-boundary for name-like terms;
                          terms < 4 chars skipped to avoid absurd matches)
  (b) email addresses  — anyone's, generic pattern
  (c) phone numbers    — generic shapes (10-15 digits, +prefixed or separator-
                         grouped; a bare unbroken digit run is treated as a
                         numeric/hex code constant, not a phone number — see
                         _looks_like_code_constant()). A digit run glued onto
                         a preceding word via hyphens (a model ID, package
                         version, container tag) is also exempted — see
                         _looks_like_versioned_identifier().
  (d) api-key strings  — long base64/hex constants that look like secrets

Precedent pass (denylist categories only): the gate exists to catch NEW
exposure in a diff. If a denylist hit's exact matched line — whitespace-
normalized — already exists verbatim in some tracked file in the BASE tree the
diff is measured against (the 'before' side of `git diff`), that line is by
definition not new, so the hit is downgraded from a failure to a printed INFO
note ("precedented: identical line ships at <path>"). This cannot false-
negative a genuine leak: newly-introduced personal data has no identical line
in the shipped tree, so it has no precedent to hide behind. Deliberately scoped
to denylist hits ONLY — pattern hits (email/phone/api-key) are never
precedent-downgraded. There are still NO allowlists and NO path exemptions: the
downgrade is decided purely by the tree's own prior content, line by line.

Reserved documentation values (email/phone pattern hits only): an address at an
RFC-reserved domain (example.com/.org/.net and their subdomains per RFC 2606;
the .example/.invalid/.test TLDs per RFC 6761) or a phone number in the NANP
fictional 555-01XX block is DEFINITIONALLY an example/documentation value — a
public standard reserves it as unownable, so it can never belong to a real
person and flagging it can never catch a real leak. Such a hit is downgraded to
the same INFO note as a precedented one. Same discipline: ONLY standard-reserved
domains/ranges qualify — no other domain or number range is ever exempted, and
denylist hits are never downgraded this way (a reserved-domain address that is
also on the operator's denylist still fails).

Note on instance-data references: matching bare ~/.aos/data or vault/log *paths*
was deliberately dropped. Framework code references those roots constantly and
legitimately (they are AOS's data dirs), so a path check produces only false
positives — a path like ~/vault/log/2026-07-12.md carries a date, not personal
data. What actually leaks is the *content* of those files (names, contacts,
emails, phones), which the denylist and the email/phone patterns already catch.

REDACTION: the matched personal string is NEVER printed. Output shows the
category and a short SHA-256 of the matched text so a human can correlate the
finding without the tool itself leaking the secret.

Usage:
  privacy-scan                    # scan staged changes (git diff --cached)
  privacy-scan <ref-range>        # e.g. origin/main..HEAD  (or any git diff arg)
  privacy-scan --denylist PATH    # override denylist location
  privacy-scan --help

Exit codes:
  0  clean
  1  personal data found (block the ship)
  2  usage / environment error (not a git repo, etc.)

If the denylist is missing (e.g. a fresh install that never ran
privacy-denylist-refresh) the denylist checks are skipped with a warning; the
generic pattern checks still run.
"""

from __future__ import annotations

import argparse
import hashlib
import os
import re
import subprocess
import sys
from pathlib import Path

DEFAULT_DENYLIST = Path(os.path.expanduser("~")) / ".aos/config/privacy-denylist.txt"

MIN_TERM_LEN = 4

# ── Generic patterns ────────────────────────────────────────────────────────
EMAIL_RE = re.compile(r"[A-Za-z0-9._%+\-]+@[A-Za-z0-9.\-]+\.[A-Za-z]{2,}")

# Phone shapes: optional +, groups of digits with separators, >= 10 digits total.
# The character class is broad; a digit-count check downstream rejects noise.
PHONE_RE = re.compile(
    r"(?<![\w.])(\+?\d[\d\s().\-]{8,}\d)(?![\w])"
)

# API-key-ish: a quoted long token from the base64/hex/url-safe alphabet.
APIKEY_RE = re.compile(r"""['"]([A-Za-z0-9+/=_\-]{40,})['"]""")

# Reserved documentation values — addresses/numbers that a public standard
# reserves as unownable, so they are DEFINITIONALLY example/documentation
# values and can never belong to a real person. Flagging them can never catch a
# real leak, so an email/phone pattern hit landing on one is downgraded to an
# INFO note (never a ship-blocking failure). This is deliberately narrow: ONLY
# the domains/ranges a standard reserves qualify — no other domain or number
# range is ever exempted.
#   RFC 2606 §3  reserves example.com / example.org / example.net (+ subdomains)
#   RFC 6761 §6.5 reserves the .example / .invalid / .test TLDs
RESERVED_EMAIL_SLDS = ("example.com", "example.org", "example.net")
RESERVED_EMAIL_TLDS = ("example", "invalid", "test")


def _is_reserved_email_domain(domain: str) -> bool:
    d = domain.strip().lower().rstrip(".")
    if not d:
        return False
    if d.rsplit(".", 1)[-1] in RESERVED_EMAIL_TLDS:
        return True
    return any(d == s or d.endswith("." + s) for s in RESERVED_EMAIL_SLDS)


def _is_reserved_phone(digits: str) -> bool:
    """True for a North American Numbering Plan fictional number — exchange 555,
    subscriber 0100-0199 (the 555-01XX block the plan reserves for use in
    fiction/examples). Such a number is never assignable, so it can't be a real
    personal phone. Scoped to NANP-shaped input (10 digits, or 11 with the
    country-code 1); any other length/country is left as-is."""
    if len(digits) == 11 and digits.startswith("1"):
        national = digits[1:]
    elif len(digits) == 10:
        national = digits
    else:
        return False
    return national[3:6] == "555" and national[6:8] == "01"

# Files/paths where long hashes and personal references are expected & benign.
DOC_SUFFIXES = {".md", ".markdown", ".rst", ".txt"}
# Machine-generated dependency manifests: full of hash/base64 blobs whose digit
# runs trip the phone/key heuristics but are never personal data. Skipped for
# the generic email/phone/api-key patterns (denylist terms still checked).
LOCK_NAMES = {
    "go.sum", "go.mod", "package-lock.json", "yarn.lock", "pnpm-lock.yaml",
    "uv.lock", "poetry.lock", "cargo.lock", "package.resolved", "gemfile.lock",
    "composer.lock", "flake.lock",
}
LOCK_SUFFIXES = {".lock", ".sum"}
HASH_CONTEXT_RE = re.compile(
    r"\b(sha1|sha256|sha512|md5|hash|integrity|checksum|digest|revision|commit)\b",
    re.IGNORECASE,
)


class Hit:
    __slots__ = ("path", "line", "category", "digest", "content",
                 "precedented", "precedent_path", "note")

    def __init__(self, path: str, line: int, category: str, matched: str,
                 content: str = ""):
        self.path = path
        self.line = line
        self.category = category
        self.digest = hashlib.sha256(matched.lower().encode()).hexdigest()[:10]
        # Full added-line text the match came from — needed by the precedent
        # pass to compare whole lines against the base tree. Never printed.
        self.content = content
        # A hit is 'precedented' when it is downgraded from a ship-blocking
        # failure to an INFO note because it is definitionally not new exposure:
        # either an identical line already ships at base (precedent pass, sets
        # precedent_path) or the matched value is a standard-reserved
        # documentation value (reserved domain / fictional phone range). `note`
        # holds the human-readable reason printed for the INFO line.
        self.precedented = False
        self.precedent_path: str | None = None
        self.note: str = ""

    def key(self):
        return (self.path, self.line, self.category, self.digest)


# ── Denylist ────────────────────────────────────────────────────────────────
def load_denylist(path: Path):
    """Parse the denylist into a list of (compiled_regex, category, term_hash).

    Terms < MIN_TERM_LEN chars are skipped. Name-like terms (letters/spaces) get
    word-boundary anchoring to avoid matching inside larger words; terms with
    punctuation (emails, phones, domains) match as escaped substrings.
    """
    entries = []
    if not path.exists():
        return entries, False

    category = "denylist"
    for raw in path.read_text(errors="replace").splitlines():
        line = raw.strip()
        m = re.match(r"#\s*==\s*category:\s*([a-z0-9_\-]+)\s*==", line, re.IGNORECASE)
        if m:
            category = m.group(1).lower()
            continue
        if not line or line.startswith("#"):
            continue
        term = line
        if len(term) < MIN_TERM_LEN:
            continue
        escaped = re.escape(term)
        # Name-like: only word chars, spaces, and simple name punctuation.
        if re.fullmatch(r"[\w][\w .'\-]*[\w]", term):
            pattern = r"(?<!\w)" + escaped + r"(?!\w)"
        else:
            pattern = escaped
        try:
            rx = re.compile(pattern, re.IGNORECASE)
        except re.error:
            continue
        entries.append((rx, f"denylist:{category}", term))
    return entries, True


# ── Diff parsing ────────────────────────────────────────────────────────────
def iter_added_lines(diff_text: str):
    """Yield (path, new_line_number, content) for every added ('+') diff line."""
    path = None
    new_lineno = 0
    for line in diff_text.splitlines():
        if line.startswith("+++ "):
            p = line[4:].strip()
            if p == "/dev/null":
                path = None
            else:
                # Strip a/ b/ prefix and optional tab-suffixed metadata.
                p = p.split("\t", 1)[0]
                if p.startswith("b/") or p.startswith("a/"):
                    p = p[2:]
                path = p
            continue
        if line.startswith("--- "):
            continue
        if line.startswith("@@"):
            m = re.search(r"\+(\d+)", line)
            new_lineno = int(m.group(1)) if m else 0
            continue
        if line.startswith("+"):
            if path is not None:
                yield path, new_lineno, line[1:]
            new_lineno += 1
        elif line.startswith("-"):
            continue
        else:
            # context line (starts with space) or diff header noise
            if line.startswith(" ") or line == "":
                new_lineno += 1


def is_doc(path: str) -> bool:
    return Path(path).suffix.lower() in DOC_SUFFIXES


def is_lockish(path: str) -> bool:
    name = Path(path).name.lower()
    return name in LOCK_NAMES or Path(name).suffix in LOCK_SUFFIXES


def looks_key_like(token: str) -> bool:
    """A real key mixes letter cases and digits; a git sha or word won't."""
    has_lower = any(c.islower() for c in token)
    has_upper = any(c.isupper() for c in token)
    has_digit = any(c.isdigit() for c in token)
    return has_digit and (has_lower and has_upper)


def _looks_like_code_constant(raw: str) -> bool:
    """True if a PHONE_RE match is a bare numeric/hex code constant rather
    than a phone number: magic numbers (2**32, byte counts), hash-derived
    integers, or a digit run lifted from inside a longer hex token (a commit
    SHA, a UUID segment). A hex literal's ``0x``/``0X`` prefix already fails
    PHONE_RE's own word-boundary lookbehind, so that case never reaches here
    — this only needs to catch the shapes that slip past it.

    Real phone numbers are essentially always either international-prefixed
    (``+...``) or grouped with separators (spaces, dashes, dots, parens) —
    that's true of every number in this operator's own denylist. A bare,
    unbroken run of digits with neither is exactly as likely to be a numeric
    constant as a phone number, so it's treated as non-phone-shaped. Known
    phone numbers (denylist-listed, regardless of formatting) are still
    caught separately by the denylist pass above this one.
    """
    return not raw.startswith("+") and re.fullmatch(r"\d+", raw) is not None


def _looks_like_versioned_identifier(content: str, start: int, end: int) -> bool:
    """True if a PHONE_RE match sits inside a larger hyphen-glued identifier
    token that also contains letters — a model ID (``claude-haiku-4-5-
    20251001``), package name, or container tag, not a phone number.

    Extends outward from the match through ``[\\w-]`` (no whitespace) to
    find the full contiguous token, then checks for a letter outside the
    matched digit span. A real phone number is never glued directly onto a
    preceding word via a bare hyphen with no space — it's either freestanding
    (quoted, after a colon/equals with a space) or itself all digits and
    separators, so this can't false-negative a genuine phone number the way
    a domain- or content-based allowlist would.
    """
    s = start
    while s > 0 and re.match(r"[\w\-]", content[s - 1]):
        s -= 1
    e = end
    while e < len(content) and re.match(r"[\w\-]", content[e]):
        e += 1
    return any(c.isalpha() for c in content[s:e])


def scan_diff(diff_text: str, denylist, precedent_lookup=None):
    hits = []
    for path, lineno, content in iter_added_lines(diff_text):
        spans = []  # (start, end) ranges already claimed by denylist matches

        # (a) denylist terms
        for rx, category, term in denylist:
            for m in rx.finditer(content):
                spans.append((m.start(), m.end()))
                hits.append(Hit(path, lineno, category, term, content=content))

        def overlaps(s, e):
            return any(not (e <= a or s >= b) for a, b in spans)

        lockish = is_lockish(path)

        # (b) emails — skip if already covered by a denylist hit or a lockfile
        if not lockish:
            for m in EMAIL_RE.finditer(content):
                if not overlaps(m.start(), m.end()):
                    addr = m.group(0)
                    h = Hit(path, lineno, "email", addr, content=content)
                    if _is_reserved_email_domain(addr.rsplit("@", 1)[-1]):
                        h.precedented = True
                        h.note = "reserved documentation domain"
                    hits.append(h)

        # (c) phones — require 10-15 digits, skip denylist-covered spans & lockfiles
        if not lockish:
            for m in PHONE_RE.finditer(content):
                raw = m.group(1)
                digits = re.sub(r"\D", "", raw)
                if len(digits) < 10 or len(digits) > 15:
                    continue
                if _looks_like_code_constant(raw):
                    continue
                if _looks_like_versioned_identifier(content, m.start(1), m.end(1)):
                    continue
                if not overlaps(m.start(), m.end()):
                    h = Hit(path, lineno, "phone", digits, content=content)
                    if _is_reserved_phone(digits):
                        h.precedented = True
                        h.note = "reserved fictional phone range"
                    hits.append(h)

        # (d) api-key-shaped constants — skip docs, lock files, and hash contexts
        if not is_doc(path) and not lockish and not HASH_CONTEXT_RE.search(content):
            for m in APIKEY_RE.finditer(content):
                token = m.group(1)
                if looks_key_like(token):
                    hits.append(Hit(path, lineno, "api-key", token))

    # Deduplicate identical findings
    seen = set()
    unique = []
    for h in hits:
        if h.key() not in seen:
            seen.add(h.key())
            unique.append(h)

    # Precedent pass (denylist categories only) — see module docstring.
    if precedent_lookup is not None:
        cache: dict[str, str | None] = {}
        for h in unique:
            if not h.category.startswith("denylist:"):
                continue
            key = _norm_ws(h.content)
            if not key:
                continue
            if key not in cache:
                cache[key] = precedent_lookup(h.content)
            if cache[key]:
                h.precedented = True
                h.precedent_path = cache[key]
                h.note = f"precedented: identical line ships at {cache[key]}"
    return unique


# ── Git ─────────────────────────────────────────────────────────────────────
def get_diff(ref_arg: str | None):
    """Return diff text. ref_arg None → staged (--cached); else `git diff <arg>`."""
    base = ["git", "diff", "--no-color", "--no-ext-diff"]
    if ref_arg:
        cmd = base + [ref_arg]
    else:
        cmd = base + ["--cached"]
    try:
        out = subprocess.run(
            cmd, capture_output=True, text=True, check=False
        )
    except FileNotFoundError:
        print("error: git not found", file=sys.stderr)
        sys.exit(2)
    if out.returncode != 0:
        sys.stderr.write(out.stderr)
        print("error: git diff failed (not a repo, or bad ref?)", file=sys.stderr)
        sys.exit(2)
    return out.stdout


# ── Precedent pass ──────────────────────────────────────────────────────────
def _norm_ws(s: str) -> str:
    """Whitespace-normalize a line: collapse every run of whitespace to a single
    space and strip the ends. Two lines are 'the same line' iff their normalized
    forms are equal — so indentation and internal spacing differences don't
    matter, but a different token or a longer line does."""
    return " ".join(s.split())


def base_ref_of(ref_arg: str | None) -> str:
    """The base tree the diff is measured against — the same side `git diff`
    treats as 'before'. This is where the precedent pass looks for an
    already-shipped identical line.

      None                → staged diff (`--cached`) is index-vs-HEAD → base HEAD
      'A..B' / 'A' / '<sha>' → base is the left/only ref (`git diff` reads it as
                               the 'before' tree)
      'A...B'             → git uses merge-base(A, B) as the base; mirror that
    """
    if not ref_arg:
        return "HEAD"
    if "..." in ref_arg:
        left, right = ref_arg.split("...", 1)
        left = left or "HEAD"
        right = right or "HEAD"
        mb = subprocess.run(["git", "merge-base", left, right],
                            capture_output=True, text=True, check=False)
        if mb.returncode == 0 and mb.stdout.strip():
            return mb.stdout.strip()
        return left
    if ".." in ref_arg:
        return ref_arg.split("..", 1)[0] or "HEAD"
    return ref_arg


def _precedent_path(content: str, base_ref: str, cwd: str | None = None):
    """Return the path of a tracked file in *base_ref* that already contains a
    line whitespace-identical to *content*, or None. One `git grep -F` per call;
    callers cache by normalized line so it runs once per unique matched line.

    git grep does a fast fixed-string substring scan for the stripped line; the
    normalized full-line equality check below rejects substring/near matches
    (a longer line that merely contains the text is NOT the same line), so this
    only ever fires on a genuinely identical shipped line.
    """
    needle = content.strip()
    if not needle:
        return None
    target = _norm_ws(content)
    try:
        out = subprocess.run(
            ["git", "grep", "-F", "-n", "-e", needle, base_ref, "--"],
            capture_output=True, text=True, cwd=cwd, check=False,
        )
    except FileNotFoundError:
        return None
    if out.returncode not in (0, 1):  # 0 = matches, 1 = none, >1 = real error
        return None
    for line in out.stdout.splitlines():
        # `git grep -n <tree>` → "<tree>:<path>:<lineno>:<line>"
        parts = line.split(":", 3)
        if len(parts) < 4:
            continue
        _tree, path, _lineno, base_content = parts
        if _norm_ws(base_content) == target:
            return path
    return None


def make_precedent_lookup(base_ref: str, cwd: str | None = None):
    """Bind a precedent lookup to a base ref for scan_diff to call per line."""
    def lookup(content: str):
        return _precedent_path(content, base_ref, cwd=cwd)
    return lookup


# ── Reporting ───────────────────────────────────────────────────────────────
def report(hits):
    # Downgraded hits (identical line already ships at base, or a standard-
    # reserved documentation value) are not NEW exposure — print them as INFO
    # notes and exclude them from the pass/fail decision.
    precedented = [h for h in hits if h.precedented]
    failures = [h for h in hits if not h.precedented]

    if precedented:
        precedented.sort(key=lambda h: (h.path, h.line, h.category))
        print(f"privacy-scan: {len(precedented)} info note(s) — "
              "precedented or reserved documentation values, not new exposure")
        for h in precedented:
            reason = h.note or "downgraded"
            print(f"  INFO {reason}  ({h.path}:{h.line} "
                  f"[{h.category}] sha256:{h.digest})")
        print("")

    if not failures:
        print("privacy-scan: clean — no new personal data in diff")
        return 0

    failures.sort(key=lambda h: (h.path, h.line, h.category))
    print(f"privacy-scan: {len(failures)} finding(s) — matched strings redacted\n")
    for h in failures:
        print(f"  {h.path}:{h.line}  [{h.category}]  sha256:{h.digest}")

    by_cat: dict[str, int] = {}
    by_file: dict[str, int] = {}
    for h in failures:
        by_cat[h.category] = by_cat.get(h.category, 0) + 1
        by_file[h.path] = by_file.get(h.path, 0) + 1
    print("\n  By category:")
    for cat in sorted(by_cat):
        print(f"    {cat}: {by_cat[cat]}")
    print("  By file:")
    for f in sorted(by_file):
        print(f"    {f}: {by_file[f]}")
    return 1


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Scan a git diff for operator personal data.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("ref", nargs="?", default=None,
                    help="git diff ref/range (default: staged changes)")
    ap.add_argument("--denylist", type=Path, default=DEFAULT_DENYLIST,
                    help=f"denylist path (default: {DEFAULT_DENYLIST})")
    args = ap.parse_args()

    denylist, present = load_denylist(args.denylist)
    if not present:
        print(f"privacy-scan: warning — denylist not found at {args.denylist}; "
              "running generic checks only (run privacy-denylist-refresh to enable "
              "denylist matching)", file=sys.stderr)

    diff_text = get_diff(args.ref)
    if not diff_text.strip():
        print("privacy-scan: clean — empty diff")
        return 0

    precedent_lookup = make_precedent_lookup(base_ref_of(args.ref))
    hits = scan_diff(diff_text, denylist, precedent_lookup=precedent_lookup)
    return report(hits)


if __name__ == "__main__":
    sys.exit(main())
