#!/usr/bin/env bash
# check-update — two-phase update system for AOS
#
# Usage:
#   check-update              — check and notify if update available
#   check-update --apply      — check and auto-apply if available
#   check-update --continue   — phase 2: deploy after code pull (called via exec)
#   check-update --status     — just print current vs remote version
#
# Architecture:
#   Phase 1 (--apply): git pull only, then exec this script with --continue.
#   Phase 2 (--continue): runs from the NEW code on disk. Reconcile, migrate,
#   rebuild venvs, restart services, health check.
#
#   This solves the bootstrapping problem: the old script never drives deployment.
#   After pull, the process is replaced by the new script via exec.
#
# Called by:
#   - Scheduler (crons.yaml) every 2 hours
#   - User via `aos check-update` / `aos update`
#   - Dashboard update button

set +e

AOS_DIR="$HOME/aos"
STATE_FILE="$HOME/.aos/data/update-state.json"
HANDOFF_FILE="$HOME/.aos/data/update-handoff.json"
DEPLOYED_HASH_FILE="$HOME/.aos/data/deployed-hash"
LOG_PREFIX="[$(date '+%Y-%m-%d %H:%M:%S')]"

# Exported so the env-based python heredocs below can read them safely
# (avoids interpolating arbitrary strings like commit messages into code).
export AOS_DIR STATE_FILE HANDOFF_FILE DEPLOYED_HASH_FILE

mkdir -p "$(dirname "$STATE_FILE")"

log() { echo "$LOG_PREFIX $*"; }

# ── Install-type detection ───────────────────────────────────────────────────
#
# Two install shapes:
#   release — ~/aos is a symlink → ~/aos-releases/<version>/ (no .git inside).
#             Updates flow through release-manager (create + activate), driven
#             from a source git repo at ~/project/aos or ~/.aos/repo.
#   git     — ~/aos is a real git clone. Updates flow through git pull.

detect_install() {
    if [[ -L "$AOS_DIR" && ! -d "$AOS_DIR/.git" ]]; then
        echo "release"
    elif [[ -d "$AOS_DIR/.git" ]]; then
        echo "git"
    else
        echo "unknown"
    fi
}

# Find the source git repo for release-system updates.
# Mirrors release-manager's _find_repo: dev machines first, then fleet.
find_repo() {
    if [[ -d "$HOME/project/aos/.git" ]]; then
        echo "$HOME/project/aos"
    elif [[ -d "$HOME/.aos/repo/.git" ]]; then
        echo "$HOME/.aos/repo"
    else
        echo ""
    fi
}

# ── Release channels ─────────────────────────────────────────────────────────
#
# The channel (~/.aos/config/channel, default "stable") decides which git ref
# this machine tracks:
#   edge   → origin/main HEAD          (operator, same-day)
#   stable → the `stable` tag's commit (friends, promoted releases only)
# All the resolution rules live in core/lib/channels.py so they stay testable;
# the functions below just supply it the two candidate hashes and read back the
# target. If the stable tag doesn't exist yet, channels.py falls back to main.

CHANNELS_LIB="$AOS_DIR/core/lib/channels.py"

read_channel() {
    python3 "$CHANNELS_LIB" channel 2>/dev/null || echo "stable"
}

# Fetch origin/main plus the stable tag into a repo. The stable tag MOVES on
# promotion, so it must be force-updated locally (+refs/tags/...). Returns
# non-zero only if the mandatory main fetch fails (tag fetch is best-effort).
_fetch_channel_refs() {
    local repo="$1"
    git -C "$repo" fetch origin main --quiet 2>/dev/null || return 1
    git -C "$repo" fetch origin "+refs/tags/stable:refs/tags/stable" --quiet 2>/dev/null || true
    return 0
}

# Echo TAB-separated: channel  ref  target_hash  fellback(0|1)  reason
# Assumes _fetch_channel_refs already ran against $repo.
_resolve_channel_target() {
    local repo="$1"
    local main_hash stable_hash
    main_hash=$(git -C "$repo" rev-parse origin/main 2>/dev/null || echo "")
    stable_hash=$(git -C "$repo" rev-parse -q --verify "refs/tags/stable^{commit}" 2>/dev/null || echo "")
    python3 "$CHANNELS_LIB" resolve "$main_hash" "$stable_hash" 2>/dev/null
}

# ── State writers (env-based — no string interpolation into code) ────────────

_write_state() {
    # $1=status  $2=local_hash  $3=remote_hash
    STATUS="$1" LOCAL="$2" REMOTE="$3" python3 - <<'PY'
import json, datetime, os
state = {
    "last_check": datetime.datetime.now().isoformat(),
    "status": os.environ.get("STATUS", "unknown"),
    "local": os.environ.get("LOCAL", ""),
    "remote": os.environ.get("REMOTE", ""),
}
with open(os.environ["STATE_FILE"], "w") as f:
    json.dump(state, f, indent=2)
PY
}

_write_state_update() {
    # $1=local_hash  $2=remote_hash  $3=behind  $4=changes (newline-separated)
    LOCAL="$1" REMOTE="$2" BEHIND="$3" CHANGES="$4" python3 - <<'PY'
import json, datetime, os
changes = [c for c in os.environ.get("CHANGES", "").strip().split("\n") if c]
state = {
    "last_check": datetime.datetime.now().isoformat(),
    "status": "update_available",
    "local": os.environ.get("LOCAL", ""),
    "remote": os.environ.get("REMOTE", ""),
    "behind": int(os.environ.get("BEHIND", "0") or 0),
    "changes": changes,
}
with open(os.environ["STATE_FILE"], "w") as f:
    json.dump(state, f, indent=2)
PY
}

# ── Telegram notification (best-effort) ──────────────────────────────────────

notify() {
    local msg="$1"
    local bot_token chat_id
    bot_token=$("$AOS_DIR/core/bin/cli/agent-secret" get TELEGRAM_BOT_TOKEN 2>/dev/null) || return 0
    chat_id=$("$AOS_DIR/core/bin/cli/agent-secret" get TELEGRAM_CHAT_ID 2>/dev/null) || return 0
    [[ -z "$bot_token" || -z "$chat_id" ]] && return 0

    curl -s --max-time 10 -X POST "https://api.telegram.org/bot${bot_token}/sendMessage" \
        -H "Content-Type: application/json" \
        -d "{\"chat_id\": ${chat_id}, \"text\": \"${msg}\", \"parse_mode\": \"HTML\"}" \
        > /dev/null 2>&1 || true
}

# ── Check for updates ────────────────────────────────────────────────────────
#
# IMPORTANT: check() and its variants ALWAYS exit 0 for any non-catastrophic
# state — up-to-date, update-available, offline, or misconfigured. "Nothing to
# do" is not a cron failure. The result is recorded in the state file for the
# dashboard / `aos status`; it is never signalled via a non-zero exit code.
# (Returning 1 here is what generated ~1000 false "cron failed" alerts on
# release-system machines, where ~/aos has no git remote.)

check() {
    local itype
    itype=$(detect_install)
    case "$itype" in
        release) check_release ;;
        git)     check_git ;;
        *)
            log "Unknown install type (~/aos is neither a git clone nor a release symlink) — skipping check"
            _write_state "unknown_install" "" ""
            ;;
    esac
    return 0
}

# Returns 0 (true) if an update is available, 1 (false) otherwise.
# Side effect: refreshes the state file. Used by both check and apply.
update_available() {
    local itype
    itype=$(detect_install)
    if [[ "$itype" == "release" ]]; then
        check_release
    else
        check_git
    fi
    # Re-read the freshly written state file for the verdict.
    python3 - <<'PY'
import json, os, sys
try:
    s = json.load(open(os.environ["STATE_FILE"]))
except Exception:
    sys.exit(1)
sys.exit(0 if s.get("status") == "update_available" else 1)
PY
}

# ── Release-system check (drives off the source repo, compares deployed hash) ─

check_release() {
    local repo deployed_hash cur_version
    repo=$(find_repo)
    deployed_hash=$(cat "$DEPLOYED_HASH_FILE" 2>/dev/null || echo "")
    cur_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    if [[ -z "$repo" ]]; then
        log "Release system but no source repo found (checked ~/project/aos, ~/.aos/repo) — cannot check for updates"
        _write_state "no_source_repo" "$deployed_hash" "$deployed_hash"
        return 0
    fi

    _fetch_channel_refs "$repo" || {
        log "WARN: git fetch failed in $repo (network?)"
        _write_state "offline" "$deployed_hash" "$deployed_hash"
        return 0
    }

    # Resolve which ref this machine's channel tracks.
    local channel ref remote_hash fellback reason
    IFS=$'\t' read -r channel ref remote_hash fellback reason < <(_resolve_channel_target "$repo")
    if [[ -z "$remote_hash" ]]; then
        log "WARN: could not resolve $ref in $repo (channel: $channel)"
        _write_state "check_error" "$deployed_hash" "$deployed_hash"
        return 0
    fi
    [[ "$fellback" == "1" ]] && log "NOTE (stable): $reason"

    if [[ "$deployed_hash" == "$remote_hash" ]]; then
        log "Up to date ($cur_version, channel: $channel)"
        _write_state "up_to_date" "$deployed_hash" "$remote_hash"
        return 0
    fi

    local behind changes
    behind=$(git -C "$repo" rev-list --count "$deployed_hash..$remote_hash" 2>/dev/null || echo 0)
    changes=$(git -C "$repo" log --oneline "$deployed_hash..$remote_hash" 2>/dev/null | head -5)
    log "Update available on '$channel': $behind new commit(s)"
    _write_state_update "$deployed_hash" "$remote_hash" "$behind" "$changes"
    return 0
}

# ── Git-clone check (legacy path — git pull installs) ────────────────────────

check_git() {
    cd "$AOS_DIR" || { log "ERROR: AOS dir not found"; _write_state "no_aos_dir" "" ""; return 0; }

    local remote
    remote=$(git remote 2>/dev/null | head -1)
    if [[ -z "$remote" ]]; then
        log "No git remote configured — skipping update check"
        _write_state "no_remote" "" ""
        return 0
    fi

    git fetch "$remote" --quiet 2>/dev/null || {
        log "WARN: git fetch failed (network?)"
        _write_state "offline" "" ""
        return 0
    }
    # Keep the (movable) stable tag current for channel resolution.
    git fetch "$remote" "+refs/tags/stable:refs/tags/stable" --quiet 2>/dev/null || true

    local local_hash channel ref remote_hash fellback reason
    local_hash=$(git rev-parse HEAD 2>/dev/null || echo "")
    IFS=$'\t' read -r channel ref remote_hash fellback reason < <(_resolve_channel_target "$AOS_DIR")

    if [[ -z "$remote_hash" ]]; then
        log "WARN: could not resolve channel ref '$ref' (channel: $channel)"
        _write_state "check_error" "$local_hash" ""
        return 0
    fi
    [[ "$fellback" == "1" ]] && log "NOTE (stable): $reason"

    if [[ "$local_hash" == "$remote_hash" ]]; then
        log "Up to date (channel: $channel)"
        _write_state "up_to_date" "$local_hash" "$remote_hash"
        return 0
    fi

    local behind changes
    behind=$(git rev-list --count "$local_hash..$remote_hash" 2>/dev/null || echo 0)
    changes=$(git log --oneline "$local_hash..$remote_hash" 2>/dev/null | head -5)
    log "Update available on '$channel': $behind new commit(s)"
    _write_state_update "$local_hash" "$remote_hash" "$behind" "$changes"
    return 0
}

# ── Phase 1: install the new code, then hand off to phase 2 ──────────────────
#
# Both apply paths do the MINIMUM with the old code, then exec the NEW script:
#   git path     — git pull, then exec ~/aos/.../check-update --continue
#   release path — release-manager create + activate (switches the ~/aos
#                  symlink to the new release), then exec the NEW script.
#
# After exec, the old in-memory code is gone and phase 2 (deploy) runs entirely
# from the freshly installed code on disk. This solves the bootstrapping
# problem — the old script never drives its own deployment.

apply() {
    local itype
    itype=$(detect_install)
    case "$itype" in
        release) apply_release ;;
        git)     apply_git ;;
        *)
            log "ERROR: unknown install type — cannot apply update"
            notify "⚠️ Update failed: ~/aos is neither a git clone nor a release symlink."
            return 1
            ;;
    esac
}

# Write the phase-2 handoff file. Args via env to avoid code interpolation.
_write_handoff() {
    # $1=install_type $2=old_hash $3=new_hash $4=old_version $5=new_version $6=repo
    ITYPE="$1" OLD_HASH="$2" NEW_HASH="$3" OLD_VERSION="$4" NEW_VERSION="$5" REPO="$6" \
    python3 - <<'PY'
import json, datetime, os
handoff = {
    "triggered_at": datetime.datetime.now().isoformat(),
    "install_type": os.environ.get("ITYPE", "git"),
    "old_hash": os.environ.get("OLD_HASH", ""),
    "new_hash": os.environ.get("NEW_HASH", ""),
    "old_version": os.environ.get("OLD_VERSION", "unknown"),
    "new_version": os.environ.get("NEW_VERSION", "unknown"),
    "repo": os.environ.get("REPO", ""),
}
with open(os.environ["HANDOFF_FILE"], "w") as f:
    json.dump(handoff, f, indent=2)
PY
}

# ── Release-system apply (create + activate a new immutable release) ─────────

apply_release() {
    log "Phase 1 (release): building + activating new release..."

    local repo
    repo=$(find_repo)
    if [[ -z "$repo" ]]; then
        log "ERROR: no source repo found — cannot build a release"
        notify "⚠️ Update failed: no source repo (~/project/aos or ~/.aos/repo). Cannot self-update."
        return 1
    fi

    local rm="$AOS_DIR/core/bin/internal/release-manager"
    if [[ ! -x "$rm" && ! -f "$rm" ]]; then
        log "ERROR: release-manager not found at $rm"
        return 1
    fi

    local old_hash old_version
    old_hash=$(cat "$DEPLOYED_HASH_FILE" 2>/dev/null || echo "")
    old_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    _fetch_channel_refs "$repo" || {
        log "ERROR: git fetch failed in $repo"
        notify "⚠️ System update failed (git fetch). Will retry next cycle."
        return 1
    }

    # Resolve the channel target — edge builds from origin/main, stable builds
    # from the stable tag (or main until the first promotion exists).
    local channel ref new_hash fellback reason
    IFS=$'\t' read -r channel ref new_hash fellback reason < <(_resolve_channel_target "$repo")
    if [[ -z "$new_hash" ]]; then
        log "ERROR: could not resolve channel ref '$ref' in $repo (channel: $channel)"
        return 1
    fi
    [[ "$fellback" == "1" ]] && log "NOTE (stable): $reason"

    if [[ "$old_hash" == "$new_hash" ]]; then
        log "Already at $new_hash (channel: $channel) — nothing to apply"
        return 0
    fi

    local new_version release_name
    new_version=$(git -C "$repo" show "$new_hash:VERSION" 2>/dev/null || echo "unknown")
    # Release name matches release-manager's formula: <version>-<7-char hash>
    release_name="${new_version}-${new_hash:0:7}"

    # Build the immutable release from the channel's ref (idempotent — no-op if
    # it already exists).
    log "Creating release $release_name from $ref (channel: $channel) ..."
    if ! bash "$rm" create "$ref" >/dev/null 2>&1; then
        log "ERROR: release-manager create failed"
        notify "⚠️ Update failed during release build. Will retry next cycle."
        return 1
    fi

    # Activate it (validates the new release, then atomically switches ~/aos
    # and records the new deployed hash). Pass the exact target hash so the
    # deployed-hash records the channel commit, not origin/main.
    log "Activating $release_name ..."
    if ! bash "$rm" activate "$release_name" "$new_hash" >/dev/null 2>&1; then
        log "ERROR: release-manager activate failed for $release_name"
        notify "⚠️ Update failed during activation of $release_name. Still on previous release."
        return 1
    fi

    _write_handoff "release" "$old_hash" "$new_hash" "$old_version" "$new_version" "$repo"

    log "Release $release_name active ($old_version → $new_version). Handing off to new script..."

    # ~/aos now points at the new release — exec runs the NEW code.
    exec "$AOS_DIR/core/bin/crons/check-update" --continue
}

# ── Git-clone apply (legacy path — git pull installs) ────────────────────────

apply_git() {
    log "Phase 1 (git): pulling code..."

    cd "$AOS_DIR" || exit 1

    local old_hash old_version
    old_hash=$(git rev-parse HEAD 2>/dev/null)
    old_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    _fetch_channel_refs "$AOS_DIR" || {
        log "ERROR: git fetch failed"
        notify "⚠️ System update failed (git fetch). Will retry next cycle."
        return 1
    }

    local channel ref target_hash fellback reason
    IFS=$'\t' read -r channel ref target_hash fellback reason < <(_resolve_channel_target "$AOS_DIR")
    if [[ -z "$target_hash" ]]; then
        log "ERROR: could not resolve channel ref '$ref' (channel: $channel)"
        return 1
    fi
    [[ "$fellback" == "1" ]] && log "NOTE (stable): $reason"

    if [[ "$channel" == "edge" ]]; then
        # Edge tracks main — fast-forward pull, clearing any drift on retry.
        if ! git merge --ff-only "$target_hash" 2>/dev/null; then
            log "ff-only advance failed — clearing dirty state and retrying"
            git checkout -- . 2>/dev/null
            if ! git merge --ff-only "$target_hash" 2>/dev/null; then
                log "ERROR: could not advance to $target_hash"
                notify "⚠️ System update failed (git advance). Will retry next cycle."
                return 1
            fi
        fi
    else
        # Stable tracks a tag that lags main — hard-reset the framework clone to
        # the promoted commit (~/aos is read-only at runtime, so a reset is safe
        # and matches the existing dirty-state handling).
        git checkout -- . 2>/dev/null
        if ! git reset --hard "$target_hash" 2>/dev/null; then
            log "ERROR: could not reset to stable commit $target_hash"
            notify "⚠️ System update failed (stable reset). Will retry next cycle."
            return 1
        fi
    fi

    local new_hash new_version
    new_hash=$(git rev-parse HEAD 2>/dev/null)
    new_version=$(cat "$AOS_DIR/VERSION" 2>/dev/null || echo "unknown")

    _write_handoff "git" "$old_hash" "$new_hash" "$old_version" "$new_version" "$AOS_DIR"

    log "Code pulled ($old_version → $new_version). Handing off to new script..."

    # Replace this process with the NEW version of this script from disk.
    exec "$AOS_DIR/core/bin/crons/check-update" --continue
}

# ── Service venv rebuild (safe: stage → verify → atomic swap) ────────────────
#
# A service's venv must never be torn down before a working replacement
# exists. The previous implementation `rm -rf`'d the live venv and then called
# `aos deploy`, which (a) only understands pyproject.toml, so the crawler
# (requirements.txt) could never rebuild, and (b) left the service with NO venv
# whenever the rebuild failed — exactly what broke the live crawler on the
# v0.6.8 update. These helpers build the new venv at a staging path, verify the
# service's primary dependency imports, then atomically swap it in — restoring
# the old venv on any failure.

# Pick the newest available Python (3.11+) for venv creation — mirrors the
# `aos deploy` _find_python logic so rebuilds match a fresh deploy.
_find_venv_python() {
    local p minor
    for p in /opt/homebrew/bin/python3.13 /opt/homebrew/bin/python3 "$HOME/.local/bin/python3"; do
        if [[ -f "$p" ]]; then
            minor=$("$p" --version 2>&1 | awk '{print $2}' | cut -d. -f2)
            if [[ "$minor" =~ ^[0-9]+$ && "$minor" -ge 11 ]]; then
                echo "$p"
                return
            fi
        fi
    done
    echo "python3"
}

# Extract the newline-separated dependency list from a pyproject.toml.
_pyproject_deps() {
    PYPROJECT="$1" python3 - <<'PY'
import os, re
p = os.environ["PYPROJECT"]
try:
    import tomllib
    with open(p, "rb") as f:
        deps = tomllib.load(f).get("project", {}).get("dependencies", [])
except Exception:
    deps = []
    in_deps = False
    for line in open(p):
        s = line.strip()
        if s == "dependencies = [":
            in_deps = True
            continue
        if in_deps and s == "]":
            break
        if in_deps:
            m = re.search(r'"(.+?)"', line)
            if m:
                deps.append(m.group(1))
print("\n".join(deps))
PY
}

# Verify the service's primary dependency imports inside the freshly built
# venv. Runs the check with the NEW venv's own interpreter so it exercises the
# real install. Resolves the correct import name from the distribution's
# top_level.txt (package name != import name for e.g. python-telegram-bot →
# telegram); falls back to a normalized name, then to "distribution present".
# Exit 0 = good venv, 1 = do not swap it in.
_verify_primary_import() {
    local venv_py="$1" depfile="$2" depmode="$3"
    DEPFILE="$depfile" DEPMODE="$depmode" "$venv_py" - <<'PY'
import os, re, sys, importlib
from importlib import metadata

depfile = os.environ["DEPFILE"]
depmode = os.environ["DEPMODE"]

deps = []
if depmode == "pyproject":
    try:
        import tomllib
        with open(depfile, "rb") as f:
            deps = tomllib.load(f).get("project", {}).get("dependencies", [])
    except Exception:
        in_deps = False
        for line in open(depfile):
            s = line.strip()
            if s == "dependencies = [":
                in_deps = True
                continue
            if in_deps and s == "]":
                break
            if in_deps:
                m = re.search(r'"(.+?)"', line)
                if m:
                    deps.append(m.group(1))
else:
    for line in open(depfile):
        s = line.strip()
        if not s or s.startswith("#") or s.startswith("-"):
            continue
        deps.append(s)

if not deps:
    print("no-deps")
    sys.exit(0)

name = re.split(r"[<>=!~;\[ ]", deps[0], maxsplit=1)[0].strip()
if not name:
    print("no-name")
    sys.exit(0)

cands = []
# Preferred: reverse the top-level-module → distribution map (handles the
# package-name != import-name case, e.g. python-telegram-bot → telegram, even
# for modern wheels that ship no top_level.txt).
try:
    pd = metadata.packages_distributions()
    cands = [mod for mod, dists in pd.items() if name in dists]
except Exception:
    pass
if not cands:
    try:
        tl = metadata.distribution(name).read_text("top_level.txt")
        if tl:
            cands = [m.strip() for m in tl.splitlines() if m.strip() and not m.startswith("_")]
    except Exception:
        pass
if not cands:
    cands = [name.replace("-", "_").lower(), name.replace("-", "").lower()]

for m in cands:
    try:
        importlib.import_module(m)
        print("import-ok:" + m)
        sys.exit(0)
    except Exception:
        continue

# Import may fail for reasons unrelated to a broken install (heavy optional
# side-effect imports). A resolvable distribution still proves the install
# landed — accept it rather than reject a good venv.
try:
    metadata.distribution(name)
    print("dist-ok:" + name)
    sys.exit(0)
except Exception:
    pass

print("FAIL:" + name)
sys.exit(1)
PY
}

# Rebuild one service's venv safely. Returns 0 on success (or nothing to do),
# 1 on failure — the live venv is always left in a working state.
_rebuild_service_venv() {
    local svc="$1"
    local src="$AOS_DIR/core/services/$svc"
    local dst="$HOME/.aos/services/$svc"
    local venv="$dst/.venv"
    local staging="$dst/.venv.new"
    local backup="$dst/.venv.old"

    # Choose the dependency source: pinned lock first, then requirements.txt,
    # then pyproject.toml. Services without any of these (Go services, or
    # stdlib-only Python) have no venv to rebuild.
    local depfile="" depmode=""
    if [[ -f "$src/requirements.lock" ]]; then
        depfile="$src/requirements.lock"; depmode="req"
    elif [[ -f "$src/requirements.txt" ]]; then
        depfile="$src/requirements.txt"; depmode="req"
    elif [[ -f "$src/pyproject.toml" ]]; then
        depfile="$src/pyproject.toml"; depmode="pyproject"
    else
        log "  $svc has no requirements/pyproject — no venv to rebuild, skipping"
        return 0
    fi

    local py_bin
    py_bin=$(_find_venv_python)

    # Clear any leftover staging/backup from a previously interrupted rebuild.
    rm -rf "$staging" "$backup"

    log "  Staging new $svc venv ($depmode: $(basename "$depfile"))..."
    if ! uv venv "$staging" --python "$py_bin" >/dev/null 2>&1 || [[ ! -x "$staging/bin/python" ]]; then
        log "  ERROR: $svc venv creation failed — keeping existing venv"
        rm -rf "$staging"
        return 1
    fi

    local install_ok=false
    if [[ "$depmode" == "req" ]]; then
        if uv pip install -p "$staging/bin/python" -r "$depfile" >/dev/null 2>&1; then
            install_ok=true
        fi
    else
        local deps
        deps=$(_pyproject_deps "$depfile")
        if [[ -n "$deps" ]] && echo "$deps" | uv pip install -p "$staging/bin/python" -r - >/dev/null 2>&1; then
            install_ok=true
        fi
    fi
    if [[ "$install_ok" != true ]]; then
        log "  ERROR: $svc dependency install failed — keeping existing venv"
        rm -rf "$staging"
        return 1
    fi

    if ! _verify_primary_import "$staging/bin/python" "$depfile" "$depmode"; then
        log "  ERROR: $svc primary-dependency import check failed — keeping existing venv"
        rm -rf "$staging"
        return 1
    fi

    # Atomic swap: move the live venv aside, promote staging, delete the old
    # copy. On any failure mid-swap, restore the backup so the service keeps a
    # working venv.
    if [[ -d "$venv" ]]; then
        if ! mv "$venv" "$backup"; then
            log "  ERROR: $svc could not move old venv aside — keeping existing venv"
            rm -rf "$staging"
            return 1
        fi
    fi
    if ! mv "$staging" "$venv"; then
        log "  ERROR: $svc swap failed — restoring previous venv"
        [[ -d "$backup" ]] && mv "$backup" "$venv"
        rm -rf "$staging"
        return 1
    fi
    rm -rf "$backup"
    log "  ✓ $svc venv rebuilt"
    return 0
}

# ── Service restart ─────────────────────────────────────────────────────────
#
# Restart a LaunchAgent so it picks up new code/venv WITHOUT ever leaving the
# job unloaded.
#
# `launchctl bootout` is asynchronous — it returns before launchd has finished
# tearing the job down. Bootstrapping immediately after (the old inline
# bootout → bootstrap → kickstart sequence did, with every error swallowed by
# 2>/dev/null) races the teardown; when bootstrap loses that race it fails
# silently and the job is left booted-out. That is exactly how com.aos.bridge
# vanished during the v0.6.10 update cycle: plist intact, venv intact, job gone.
#
# This helper is the single guarded path for restarting a service. It settles
# after bootout, verifies the bootstrap actually registered the job, retries
# the bootstrap if it didn't, and only then kickstarts. It never returns having
# left the service unloaded silently — either the job is loaded, or it returns
# non-zero so the caller escalates. This mirrors the settle-then-verify pattern
# migrations 054/056/071 use (see those for the drain-blocking incident).
_restart_launchagent() {
    # $1 (uid) retained for signature compatibility; service_ctl derives uid.
    local la_name="$2" la_plist="$3"

    # Route through the shared guarded choke-point (core/infra/lib/service_ctl.py)
    # so bash and python callers share ONE implementation of the settle → verify
    # → retry sequence, and every restart lands in the lifecycle audit log. It
    # returns non-zero only when the job could not be verified loaded — never
    # having silently left it unloaded.
    if "$AOS_DIR/core/bin/internal/aos-python" \
            "$AOS_DIR/core/infra/lib/service_ctl.py" restart "$la_name" \
            --plist "$la_plist" --actor "check-update"; then
        return 0
    fi
    log "  ERROR: $la_name failed guarded restart — service left DOWN"
    return 1
}

# ── Phase 2: Deploy (runs from NEW code on disk) ────────────────────────────
#
# This function is always executed from the freshly pulled script.
# It reads the handoff file written by phase 1, then:
# 1. Deletes the handoff (idempotency — crash mid-deploy won't re-migrate)
# 2. Runs reconcile, migrations, sync, venv rebuild, restart, health check

deploy() {
    cd "$AOS_DIR" || exit 1

    if [[ ! -f "$HANDOFF_FILE" ]]; then
        log "No handoff file — nothing to deploy"
        return 0
    fi

    local install_type old_hash new_hash old_version new_version repo
    install_type=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE')).get('install_type','git'))" 2>/dev/null)
    old_hash=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE')).get('old_hash',''))" 2>/dev/null)
    new_hash=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE')).get('new_hash',''))" 2>/dev/null)
    old_version=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE')).get('old_version','unknown'))" 2>/dev/null)
    new_version=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE')).get('new_version','unknown'))" 2>/dev/null)
    repo=$(python3 -c "import json; print(json.load(open('$HANDOFF_FILE')).get('repo',''))" 2>/dev/null)

    # Delete handoff BEFORE destructive work — idempotency guard.
    rm -f "$HANDOFF_FILE"

    log "Phase 2 ($install_type): deploying $old_version → $new_version"

    # Auto-convert to release system if still a git clone
    if [ -d "$AOS_DIR/.git" ] && [ -f "$AOS_DIR/core/bin/internal/release-manager" ]; then
        log "Detected git clone at ~/aos — converting to release system..."
        bash "$AOS_DIR/core/bin/internal/release-manager" convert
        convert_status=$?
        if [[ $convert_status -eq 0 ]]; then
            log "Conversion successful. Continuing deploy from new release..."
            # After conversion, AOS_DIR is now a symlink — re-enter it
            cd "$AOS_DIR" || exit 1
            notify "🔄 Converted to release system. ~/aos is now read-only. Backup at ~/aos-backup/"
        else
            log "WARN: Release conversion failed — continuing with git clone"
            notify "⚠️ Release conversion failed on this machine. Still on git clone. Check logs."
        fi
    fi

    # Always run reconcile
    log "Running reconcile..."
    "$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/reconcile/runner.py" run \
        2>>"$HOME/.aos/logs/reconcile-stderr.log" || true

    # Skip the rest only if there's nothing to do: version didn't change AND
    # no migrations are pending. VERSION is a human-facing release marker,
    # not the source of truth for migration state — a release can ship
    # migrations without bumping VERSION (this happened: wave 3 shipped 4
    # migrations on an unchanged version, and this gate skipped them all
    # until run manually). The migration trigger must be pending count from
    # the runner itself, independent of the version delta.
    local pending_count
    pending_count=$("$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/migrations/runner.py" pending-count 2>/dev/null)
    [[ "$pending_count" =~ ^[0-9]+$ ]] || pending_count=0

    if [[ "$old_version" == "$new_version" && "$pending_count" -eq 0 ]]; then
        log "No version change ($old_version), no pending migrations — reconcile only"
        return 0
    fi

    if [[ "$old_version" == "$new_version" ]]; then
        log "No version change ($old_version) but $pending_count migration(s) pending — running migrations"
    fi

    # Run migrations
    log "Running migrations..."
    "$AOS_DIR/core/bin/internal/aos-python" "$AOS_DIR/core/infra/migrations/runner.py" migrate 2>/dev/null || {
        log "ERROR: migrations failed"
        notify "⚠️ Update to $new_version: migrations failed. Services not restarted."
        return 1
    }

    # Sync
    log "Syncing..."
    for cmd in sync-skills sync-agents sync-rules sync-mcp; do
        bash "$AOS_DIR/core/bin/cli/aos" "$cmd" 2>/dev/null || true
    done

    # Auto-discover which services changed and rebuild their venvs.
    # Release installs have no .git in ~/aos, so diff in the source repo using
    # the old/new hashes from the handoff. Git installs diff in ~/aos directly.
    # Match every dependency-carrying file style, not just pyproject.toml — the
    # crawler service pins its deps in requirements.txt, so a pyproject-only
    # filter never noticed its changes.
    local changed_services=""
    if [[ -n "$old_hash" && -n "$new_hash" ]]; then
        local diff_cmd
        if [[ "$install_type" == "release" && -d "$repo/.git" ]]; then
            diff_cmd=(git -C "$repo" diff --name-only "$old_hash..$new_hash")
        else
            diff_cmd=(git diff --name-only "$old_hash..HEAD")
        fi
        changed_services=$("${diff_cmd[@]}" 2>/dev/null \
            | grep -E "core/services/[^/]+/(pyproject\.toml|requirements\.(txt|lock)|[^/]+\.py)" \
            | sed 's|core/services/\([^/]*\)/.*|\1|' \
            | sort -u || true)
    fi

    if [[ -n "$changed_services" ]]; then
        log "Code/deps changed in: $changed_services"
        for svc in $changed_services; do
            # Only touch services that are actually deployed on this machine.
            [[ -d "$HOME/.aos/services/$svc" ]] || continue
            log "Rebuilding $svc venv..."
            # _rebuild_service_venv builds the replacement at a staging path and
            # only swaps it in once the primary dependency imports — the live
            # venv is never deleted before a good replacement exists (the
            # destructive rm -rf that broke the crawler on the v0.6.8 update).
            _rebuild_service_venv "$svc" || log "  WARN: $svc venv rebuild failed — previous venv left intact"
        done
    fi

    # Auto-discover which services need restart from LaunchAgents
    local uid
    uid=$(id -u)
    local restarted_services=()

    for la_plist in "$HOME/Library/LaunchAgents/com.aos."*.plist; do
        [[ -f "$la_plist" ]] || continue
        local la_name svc_name
        la_name=$(basename "$la_plist" .plist)
        svc_name="${la_name#com.aos.}"

        if echo "$changed_services" | grep -qx "$svc_name"; then
            log "Restarting $svc_name..."
            _restart_launchagent "$uid" "$la_name" "$la_plist" \
                || log "  WARN: $svc_name restart incomplete — health check will retry"
            restarted_services+=("$la_name")
        fi
    done

    # Health check for restarted services only
    if [[ ${#restarted_services[@]} -gt 0 ]]; then
        _health_check "$uid" "$new_version" "${restarted_services[@]}"
    fi

    # Release notes + state update + notification
    local release_notes
    release_notes=$(_extract_release_notes "$new_version")

    # new_hash comes from the handoff (release installs have no .git in ~/aos).
    [[ -z "$new_hash" ]] && new_hash=$(git rev-parse HEAD 2>/dev/null || echo "")
    VERSION="$new_version" NEW_HASH="$new_hash" python3 - <<'PY'
import json, datetime, os
state = {
    "last_check": datetime.datetime.now().isoformat(),
    "last_update": datetime.datetime.now().isoformat(),
    "status": "up_to_date",
    "version": os.environ.get("VERSION", "unknown"),
    "local": os.environ.get("NEW_HASH", ""),
    "remote": os.environ.get("NEW_HASH", ""),
}
with open(os.environ["STATE_FILE"], "w") as f:
    json.dump(state, f, indent=2)
PY

    log "Update complete: $new_version"

    local note_text
    note_text="━━━━━━━━━━━━━━━━━━
AOS $new_version
━━━━━━━━━━━━━━━━━━

$release_notes

Already applied. No action needed."
    notify "$note_text"
}

# ── Health check ─────────────────────────────────────────────────────────────

_health_check() {
    local uid="$1" new_version="$2"
    shift 2
    local services=("$@")

    local max_attempts=8 attempt=0 all_up=false

    while [[ $attempt -lt $max_attempts ]]; do
        sleep 2
        attempt=$((attempt + 1))
        all_up=true
        for la in "${services[@]}"; do
            if ! launchctl list 2>/dev/null | grep -q "$la"; then
                all_up=false
                break
            fi
        done
        [[ "$all_up" == true ]] && break
        [[ $attempt -lt $max_attempts ]] && log "Health check attempt $attempt/$max_attempts — waiting..."
    done

    if [[ "$all_up" == false ]]; then
        for la in "${services[@]}"; do
            if ! launchctl list 2>/dev/null | grep -q "$la"; then
                local svc_name="${la#com.aos.}"
                log "WARN: $svc_name not running — attempting restart"
                _restart_launchagent "$uid" "$la" "$HOME/Library/LaunchAgents/${la}.plist" \
                    || log "  ERROR: $svc_name still down after guarded restart"
            fi
        done
        notify "⚠️ Update to $new_version applied but some services needed extra restart. Check 'aos status'."
    fi
}

# ── Release notes extraction ────────────────────────────────────────────────

_extract_release_notes() {
    local version="$1"
    python3 -c "
from pathlib import Path
import re

cl = Path('$AOS_DIR/CHANGELOG.md')
if not cl.exists():
    print('System updated.')
    raise SystemExit()

content = cl.read_text()
pattern = r'## ${version}\b.*?\n(.*?)(?=\n## v|\Z)'
match = re.search(pattern, content, re.DOTALL)
if not match:
    print('System updated.')
    raise SystemExit()

notes = match.group(1).strip()
lines = [l.strip() for l in notes.split('\n') if l.strip()]

summary = ''
changes = {'Added': [], 'Changed': [], 'Fixed': [], 'Removed': []}
verb_map = {'Added': 'Added', 'Changed': 'Changed', 'Fixed': 'Fixed', 'Removed': 'Removed',
            'Rewrote': 'Changed', 'Expanded': 'Changed', 'Moved': 'Changed'}
other = []

for line in lines:
    if line.startswith('Summary:'):
        summary = line.replace('Summary:', '').strip()
    elif line.startswith('- '):
        text = line[2:]
        matched = False
        for verb, cat in verb_map.items():
            if text.startswith(verb + ' '):
                changes[cat].append(text[len(verb)+1:])
                matched = True
                break
        if not matched:
            other.append(text)
    elif ':' in line and line.split(':')[0] in changes:
        cat = line.split(':')[0]
        rest = ':'.join(line.split(':')[1:]).strip().lstrip('- ')
        changes[cat].append(rest)
    elif not line.startswith('#') and not summary:
        summary = line
    elif not line.startswith('#'):
        other.append(line)

if summary:
    print(summary)
    print()

icons = {'Added': '✦', 'Changed': '↻', 'Fixed': '✓', 'Removed': '✕'}
for cat in ['Added', 'Changed', 'Fixed', 'Removed']:
    items = changes[cat]
    if not items:
        continue
    icon = icons[cat]
    for item in items[:8]:
        print(f'{icon} {item}')
    if len(items) > 8:
        print(f'  ... and {len(items)-8} more')

if other:
    for line in other[:3]:
        print(f'  {line}')
" 2>/dev/null
}

# ── Status ───────────────────────────────────────────────────────────────────

status() {
    if [[ -f "$STATE_FILE" ]]; then
        python3 -c "
import json
with open('$STATE_FILE') as f:
    s = json.load(f)
print(f\"  Status:     {s.get('status', 'unknown')}\")
print(f\"  Last check: {s.get('last_check', 'never')}\")
if s.get('behind', 0) > 0:
    print(f\"  Behind:     {s['behind']} commit(s)\")
    for c in s.get('changes', []):
        print(f\"    {c}\")
if s.get('last_update'):
    print(f\"  Last update: {s['last_update']}\")
"
    else
        echo "  No update state — run 'aos check-update' first"
    fi
}

# ── Main ─────────────────────────────────────────────────────────────────────

case "${1:-}" in
    --apply)
        # Apply only if an update is actually available. update_available()
        # refreshes the state file and returns 0 (true) when behind.
        if update_available; then
            apply
        else
            log "Already up to date"
        fi
        ;;
    --continue)
        deploy
        ;;
    --status)
        status
        ;;
    *)
        # Plain check (the every-2h cron). Always exits 0 — see note above check().
        check
        ;;
esac

exit 0
